{
  "name": "claims-scanner-app",
  "version": "1.0.0",
  "description": "Automated claims document scanner and uploader",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "claims",
    "scanner",
    "health insurance",
    "document management"
  ],
  "author": "Your Company",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "electron-store": "^8.1.0",
    "express": "^5.2.1",
    "node-notifier": "^10.0.1",
    "pg": "^8.20.0",
    "ssh2-sftp-client": "^12.1.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.yourcompany.claims-scanner",
    "productName": "Claims Scanner",
    "directories": {
      "output": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "src/assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "src/assets/icon.png",
      "category": "Office"
    }
  }
}
